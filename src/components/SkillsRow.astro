---
import { skillGroups } from '../lib/site';
---

<section class="container-x py-20 sm:py-28">
  <div class="reveal max-w-3xl mb-12">
    <p class="text-[12px] font-mono uppercase tracking-[0.2em] text-[var(--color-ink-dim)] mb-4">
      The toolkit
    </p>
    <h2 class="font-display text-3xl sm:text-4xl leading-tight tracking-tight">
      What I reach for
    </h2>
  </div>

  <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-3">
    {skillGroups.map((group) => (
      <div class="reveal">
        <h3 class="text-[13px] font-mono uppercase tracking-widest text-[var(--color-accent)] mb-4">
          {group.label}
        </h3>
        <ul class="space-y-2">
          {group.items.map((item) => (
            <li class="text-[15px] text-[var(--color-ink-soft)]">{item}</li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>
