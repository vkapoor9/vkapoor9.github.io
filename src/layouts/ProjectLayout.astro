---
import BaseLayout from './BaseLayout.astro';
import ProjectVisual from '../components/ProjectVisual.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { data, slug } = project;

const statusColors: Record<string, string> = {
  Live: 'bg-emerald-500',
  Shipped: 'bg-emerald-500',
  Active: 'bg-emerald-500',
  Beta: 'bg-amber-500',
  Prototype: 'bg-sky-500',
  Retired: 'bg-zinc-500',
};
const dotColor = statusColors[data.status] ?? 'bg-zinc-500';
---

<BaseLayout title={data.title} description={data.tagline} pathname={`/projects/${project.slug}`}>
  <article>
    <!-- Hero -->
    <div class="container-x pt-16 pb-12 sm:pt-24 sm:pb-16">
      <a href="/projects" class="reveal inline-flex items-center gap-2 text-[13px] font-mono text-[var(--color-ink-dim)] hover:text-[var(--color-ink)] transition-colors mb-10">
        <span aria-hidden="true">←</span> All work
      </a>

      <div class="reveal flex flex-wrap items-center gap-3 text-[12px] font-mono uppercase tracking-widest text-[var(--color-ink-dim)] mb-6">
        <span>{data.category}</span>
        <span class="opacity-40">·</span>
        <span>{data.role}</span>
        <span class="opacity-40">·</span>
        <span>{data.year}</span>
        <span class="opacity-40">·</span>
        <span class="inline-flex items-center gap-2">
          <span class={`w-1.5 h-1.5 rounded-full ${dotColor}`} aria-hidden="true"></span>
          {data.status}
        </span>
      </div>

      <h1 class="reveal font-display text-[clamp(2.25rem,5.5vw,4.25rem)] leading-[1.05] tracking-tight mb-6 max-w-4xl">
        {data.title}
      </h1>

      <p class="reveal text-[18px] sm:text-[20px] leading-relaxed text-[var(--color-ink-soft)] max-w-3xl mb-8">
        {data.tagline}
      </p>

      <div class="reveal flex flex-wrap items-center gap-3">
        {data.demoUrl && (
          <a
            href={data.demoUrl}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 px-4 py-2.5 rounded-full bg-[var(--color-ink)] text-[var(--color-bg)] text-[13px] font-medium hover:bg-[var(--color-accent)] transition-colors"
          >
            Visit live ↗
          </a>
        )}
        {data.repoUrl && (
          <a
            href={data.repoUrl}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 px-4 py-2.5 rounded-full border border-[var(--color-line)] text-[13px] hover:border-[var(--color-ink-dim)] transition-colors"
          >
            Source ↗
          </a>
        )}
      </div>
    </div>

    <!-- Hero visual -->
    <div class="container-x pb-12">
      <div class="reveal rounded-2xl overflow-hidden border border-[var(--color-line)] shadow-[var(--shadow-card)]">
        <ProjectVisual slug={slug} title={data.title} size="hero" />
      </div>
    </div>

    <!-- AI Angle + Stack + Metrics -->
    <div class="container-x pb-16">
      <div class="reveal grid gap-8 lg:grid-cols-12 border-y border-[var(--color-line)]/60 py-10">
        <div class="lg:col-span-7">
          <p class="text-[11px] font-mono uppercase tracking-widest text-[var(--color-accent)] mb-3">The AI part</p>
          <p class="text-[16px] sm:text-[17px] leading-relaxed text-[var(--color-ink)]">{data.aiAngle}</p>
        </div>
        <div class="lg:col-span-5">
          <p class="text-[11px] font-mono uppercase tracking-widest text-[var(--color-ink-dim)] mb-3">Stack</p>
          <div class="flex flex-wrap gap-1.5">
            {data.stack.map((s) => (
              <span class="chip">{s}</span>
            ))}
          </div>
        </div>
      </div>

      {data.metrics && data.metrics.length > 0 && (
        <div class="reveal grid grid-cols-2 sm:grid-cols-4 gap-6 sm:gap-10 py-10 border-b border-[var(--color-line)]/60">
          {data.metrics.map((m) => (
            <div>
              <div class="text-[11px] font-mono uppercase tracking-widest text-[var(--color-ink-dim)] mb-2">
                {m.label}
              </div>
              <div class="font-display text-2xl sm:text-3xl tracking-tight text-[var(--color-ink)]">
                {m.value}
              </div>
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- Body -->
    <div class="container-x pb-32">
      <div class="reveal prose-narrow mx-auto">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>
